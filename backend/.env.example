# Database Connection URI (MongoDB)
MONGO_URI=mongodb://127.0.0.1:27017/event-management

# JWT Secret for authentication tokens (Keep this long, random and secure in production)
JWT_SECRET=your_jwt_secret_here

# Network Port to listen on
PORT=5000

# Seeding configuration (Optional, for seedAdmin.js)
ADMIN_PASSWORD=adminpassword123
ADMIN_EMAIL=admin@evently.com
ADMIN_NAME="Evently Admin"

# Allowed CORS origins (comma-separated list for production)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
